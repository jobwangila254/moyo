generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  FREE
  PREMIUM
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String
  age       Int
  gender    String
  interestedIn String @default("both")
  countyId  Int
  bio       String?
  occupation String?
  likes     String   @default("[]")
  hobbies   String   @default("[]")
  photos    String   @default("[]")
  profilePicUrl String?

  phoneVerificationCode String?
  phoneVerified         Boolean  @default(false)
  passwordHash          String
  tier                  Tier     @default(FREE)
  freeUnlocksRemaining  Int      @default(0)
  unlimitedChat         Boolean  @default(false)
  chatUnlockDate        DateTime?
  isActive              Boolean  @default(true)
  onboardingComplete    Boolean  @default(false)
  boostedUntil          DateTime?
  photoModerationStatus String   @default("approved")

  county    County   @relation(fields: [countyId], references: [id])
  swipesGiven     Swipe[]       @relation("SwipesGiven")
  swipesReceived  Swipe[]       @relation("SwipesReceived")
  matchesAsUser1  Match[]       @relation("MatchUser1")
  matchesAsUser2  Match[]       @relation("MatchUser2")
  reportsFiled    Report[]      @relation("ReportReporter")
  reportsReceived Report[]      @relation("ReportReported")
  blocksGiven     Block[]       @relation("BlockBlocker")
  blocksReceived  Block[]       @relation("BlockBlocked")
  viewsGiven      ProfileView[] @relation("ViewViewer")
  viewsReceived   ProfileView[] @relation("ViewViewed")
  transactions    Transaction[]
  events          UserEvent[]
  settings        UserSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model County {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model Swipe {
  id        Int      @id @default(autoincrement())
  swiperId  Int
  swipedId  Int
  direction String
  createdAt DateTime @default(now())

  swiper    User     @relation("SwipesGiven", fields: [swiperId], references: [id])
  swiped    User     @relation("SwipesReceived", fields: [swipedId], references: [id])

  @@unique([swiperId, swipedId])
}

model Match {
  id           Int      @id @default(autoincrement())
  user1Id      Int
  user2Id      Int
  unlocked     Boolean  @default(false)
  user1FreeUsed Int     @default(0)
  user2FreeUsed Int     @default(0)
  user1LastFreeDate DateTime?
  user2LastFreeDate DateTime?
  matchedAt    DateTime @default(now())

  user1        User     @relation("MatchUser1", fields: [user1Id], references: [id])
  user2        User     @relation("MatchUser2", fields: [user2Id], references: [id])
  messages     Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  matchId   Int
  senderId  Int
  content   String
  createdAt DateTime @default(now())

  match     Match    @relation(fields: [matchId], references: [id])
}

model Transaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  type         String
  amount       Int
  mpesaReceipt String?
  matchId      Int?
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  reportedId Int
  reason     String
  details    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  reporter   User     @relation("ReportReporter", fields: [reporterId], references: [id])
  reported   User     @relation("ReportReported", fields: [reportedId], references: [id])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())

  blocker   User     @relation("BlockBlocker", fields: [blockerId], references: [id])
  blocked   User     @relation("BlockBlocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model ProfileView {
  id        Int      @id @default(autoincrement())
  viewerId  Int
  viewedId  Int
  createdAt DateTime @default(now())

  viewer    User     @relation("ViewViewer", fields: [viewerId], references: [id])
  viewed    User     @relation("ViewViewed", fields: [viewedId], references: [id])

  @@unique([viewerId, viewedId])
}

model UserEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventType String
  metadata  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model UserSettings {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  pushNotifications  Boolean  @default(true)
  matchNotifications Boolean  @default(true)
  messageNotifications Boolean @default(true)
  showAge            Boolean  @default(true)
  showDistance       Boolean  @default(true)
  profileVisible     Boolean  @default(true)

  user               User     @relation(fields: [userId], references: [id])
}
